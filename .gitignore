# Go binaries and build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/vibe-vep

# Go workspace
go.work
go.work.sum

# Dependency directories
vendor/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Test coverage
coverage.out
coverage.html

