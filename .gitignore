.env
.env.*
!.env.example

# Build directory
build/
dist/

# Data symlink for Docker builds (ln -s ~/.vibe-vep data)
data

# Temporary files
*.tmp
*.log

# TCGA test data (large MAF files, download with: make download-testdata)
testdata/tcga/*.txt

# GRCh37 test data (large MAF files, download with: scripts/download_grch37.sh)
testdata/grch37/*.txt

# Datahub GDC test data (large MAF files, download with: scripts/download_datahub_gdc.sh)
testdata/datahub_gdc/*.txt

# Datahub all test data (large MAF files, download with: scripts/download_datahub_all.sh)
testdata/datahub_all/**/*.txt
!testdata/datahub_all/**/validation_report.*
!testdata/datahub_all/**/mismatches.json
